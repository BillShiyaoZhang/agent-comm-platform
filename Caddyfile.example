agent-communication.online {
    encode gzip zstd

    # API routes → Go platform backend (Registry/Relay/MQ)
    @api {
        path /api/*
    }
    reverse_proxy @api platform:8080

    # All other requests → Next.js web UI (port 3000)
    @web {
        not path /api/*
    }
    reverse_proxy @web web:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        -Server
    }
}
